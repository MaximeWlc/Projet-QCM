


#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

#define PASS_PROF "cytech2026"

/* --- NOS STRUCTURES --- */
typedef struct {
    char nom[50];
    int points_negatifs;
    int reponses_multiples;
    int mode_sequentiel;
    int nb_questions;
} Parametres;

typedef struct {
    char intitule[500];
    char props[4][200];
    char bonnes_reponses[10];
} Question;

/* --- MODE ENSEIGNANT --- */
void mode_enseignant() {
    char pass[20];
    Parametres p;
    FILE *fichier = NULL;

    printf("\n--- ACCES ENSEIGNANT ---\n");
    printf("Entrez le mot de passe : ");
    scanf("%s", pass);

    if (strcmp(pass, PASS_PROF) != 0) {
        printf("Mot de passe incorrect !\n");
        return;
    }

    printf("Acces autorise.\n\n");

    /* 1. Saisie des reglages du QCM */
    printf("Nom du QCM (un seul mot sans espaces) : ");
    scanf("%s", p.nom);

    printf("Points negatifs (1: oui, 0: non) : ");
    scanf("%d", &p.points_negatifs);

    printf("Reponses multiples (1: oui, 0: non) : ");
    scanf("%d", &p.reponses_multiples);

    printf("Mode sequentiel - reponse obligatoire (1: oui, 0: non) : ");
    scanf("%d", &p.mode_sequentiel);

    printf("Nombre de questions a creer : ");
    scanf("%d", &p.nb_questions);

    /* 2. Creation du fichier physique */
    char nom_f[100];
    sprintf(nom_f, "%s.txt", p.nom);
    fichier = fopen(nom_f, "w");

    if (fichier == NULL) {
        printf("Erreur de creation du fichier.\n");
        return;
    }

    /* 3. Ecriture de la 'Notice' (Parametres) sur la ligne 1 */
    fprintf(fichier, "%d %d %d %d\n", p.points_negatifs, p.reponses_multiples, p.mode_sequentiel, p.nb_questions);

    /* 4. Boucle pour saisir chaque question */
    for (int i = 0; i < p.nb_questions; i++) {
        Question q;
        printf("\n--- Question %d ---\n", i + 1);
        
        printf("Enonce : ");
        scanf(" %[^\n]", q.intitule); /* Lit la phrase entiere */

        for (int j = 0; j < 4; j++) {
            printf("Proposition %c : ", 'a' + j);
            scanf(" %[^\n]", q.props[j]);
        }

        printf("Bonne(s) reponse(s) (ex: a ou abc) : ");
        scanf("%s", q.bonnes_reponses);

        /* Sauvegarde de la question dans le fichier */
        fprintf(fichier, "%s\n", q.intitule);
        fprintf(fichier, "%s\n%s\n%s\n%s\n", q.props[0], q.props[1], q.props[2], q.props[3]);
        fprintf(fichier, "%s\n", q.bonnes_reponses);
    }

    fclose(fichier);
    printf("\nQCM '%s' sauvegarde avec succes !\n", nom_f);
}

/* --- MODE ETUDIANT (Squelette pour l'instant) --- */
void mode_etudiant() {
    printf("\n--- MODE ETUDIANT ---\n");
    printf("Fonctionnalite a coder a l'etape suivante.\n");
}

/* --- MAIN --- */
int main() {
    int choix;

    do {
        printf("\n=== LOGICIEL QCM CY TECH ===\n");
        printf("1. Mode Etudiant\n");
        printf("2. Mode Enseignant\n");
        printf("3. Quitter\n");
        printf("Votre choix : ");
        
        if (scanf("%d", &choix) != 1) {
            printf("Erreur de saisie.\n");
            while(getchar() != '\n'); 
            continue;
        }

        switch(choix) {
            case 1: mode_etudiant(); break;
            case 2: mode_enseignant(); break;
            case 3: printf("Au revoir !\n"); break;
            default: printf("Choix inexistant.\n");
        }
    } while (choix != 3);

    return 0;
}
