


#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>
#include <time.h>

#define PASS_PROF "cytech2026"

/* Structure d'une question avec 4 propositions fixes */
typedef struct {
    char intitule[500];
    char propA[200];
    char propB[200];
    char propC[200];
    char propD[200];
    char bonne_reponse;
    int a_point_negatif;
} Question;

/* Fonction pour melanger un tableau de questions (algorithme de Fisher-Yates) */
void melanger_questions(Question qcm[], int taille) {
    int i, j;
    Question temp;
    for (i = taille - 1; i > 0; i--) {
        j = rand() % (i + 1);
        temp = qcm[i];
        qcm[i] = qcm[j];
        qcm[j] = temp;
    }
}

/* Pose une question, gere les erreurs de saisie et met a jour le score */
void poser_question(Question q, float *score, char *reponse_utilisateur) {
    char choix;
    int tentatives = 0;

    if (q.a_point_negatif == 1) {
        printf("[ATTENTION : Points negatifs en cas d'erreur (-0.5)]\n");
    }

    printf("%s\n", q.intitule);
    printf("a) %s\n", q.propA);
    printf("b) %s\n", q.propB);
    printf("c) %s\n", q.propC);
    printf("d) %s\n", q.propD);

    while (tentatives < 2) {
        printf("Votre choix (a, b, c ou d) : ");
        if (scanf(" %c", &choix) != 1) {
            while(getchar() != '\n'); 
            tentatives++;
            continue;
        }
        
        choix = tolower(choix);

        if (choix >= 'a' && choix <= 'd') {
            break; 
        } else {
            printf("Erreur : '%c' n'est pas valide.\n", choix);
            while(getchar() != '\n');
            tentatives++;
        }
    }

    /* Si l'utilisateur echoue 2 fois, on force une reponse fausse */
    if (tentatives >= 2) {
        printf("Saisies invalides repetees. Passage a la question suivante.\n");
        choix = 'z'; 
    }

    *reponse_utilisateur = choix;

    if (choix == q.bonne_reponse) {
        *score += 1.0;
    } else if (q.a_point_negatif == 1) {
        *score -= 0.5;
    }
    printf("\n");
}

/* Lancement d'un QCM de 10 questions */
void lancer_quizz(Question qcm[], char *nom_qcm) {
    float score = 0.0;
    char reponses_joueur[10];
    int i;
    int taille = 10;

    /* Melange des questions avant de commencer */
    melanger_questions(qcm, taille);

    printf("\n--- DEBUT DU %s ---\n\n", nom_qcm);

    for (i = 0; i < taille; i++) {
        printf("Question %d/%d :\n", i + 1, taille);
        poser_question(qcm[i], &score, &reponses_joueur[i]);
    }

    /* Plancher a 0 pour la note */
    if (score < 0.0) {
        score = 0.0;
    }

    printf("--- RESULTATS ---\n");
    printf("Votre score final est : %.2f / 10.00\n\n", score);

    printf("--- CORRIGE DETAILLE ---\n");
    for (i = 0; i < taille; i++) {
        printf("Q%d : ", i + 1);
        if (reponses_joueur[i] == qcm[i].bonne_reponse) {
            printf("Correct (%c)\n", qcm[i].bonne_reponse);
        } else if (reponses_joueur[i] == 'z') {
            printf("Faux. Saisie annulee, la bonne reponse etait '%c'.\n", qcm[i].bonne_reponse);
        } else {
            printf("Faux. Vous avez mis '%c', la bonne reponse etait '%c'.\n", reponses_joueur[i], qcm[i].bonne_reponse);
        }
    }
    printf("------------------------------\n");
}

/* Creation d'un QCM par l'enseignant */
void creer_qcm() {
    FILE *fichier = NULL;
    char nom[50];
    char nom_f[100];
    int i;

    printf("\nNom du nouveau QCM (un mot sans espace) : ");
    scanf("%s", nom);

    sprintf(nom_f, "%s.txt", nom);
    fichier = fopen(nom_f, "w");

    if (fichier == NULL) {
        printf("Erreur lors de la creation du fichier.\n");
        return;
    }

    printf("\nVous devez obligatoirement creer 10 questions.\n");
    printf("Pensez a inclure 3 ou 4 questions avec points negatifs.\n\n");

    for (i = 0; i < 10; i++) {
        Question q;
        printf("--- Question %d/10 ---\n", i + 1);
        
        printf("Enonce : ");
        scanf(" %[^\n]", q.intitule);

        printf("Proposition a : ");
        scanf(" %[^\n]", q.propA);
        printf("Proposition b : ");
        scanf(" %[^\n]", q.propB);
        printf("Proposition c : ");
        scanf(" %[^\n]", q.propC);
        printf("Proposition d : ");
        scanf(" %[^\n]", q.propD);

        printf("Bonne reponse (a, b, c ou d) : ");
        scanf(" %c", &q.bonne_reponse);

        printf("Points negatifs ? (1 = Oui, 0 = Non) : ");
        scanf("%d", &q.a_point_negatif);

        /* Ecriture dans le fichier */
        fprintf(fichier, "%s\n%s\n%s\n%s\n%s\n%c\n%d\n", 
                q.intitule, q.propA, q.propB, q.propC, q.propD, q.bonne_reponse, q.a_point_negatif);
    }

    fclose(fichier);
    printf("QCM '%s' cree et sauvegarde avec succes.\n", nom_f);
}

void mode_enseignant(Question q1[], Question q2[], Question q3[]) {
    char pass[50];
    int choix;

    printf("\n--- ESPACE ENSEIGNANT ---\n");
    printf("Mot de passe : ");
    scanf("%s", pass);

    if (strcmp(pass, PASS_PROF) != 0) {
        printf("Acces refuse.\n");
        return;
    }

    do {
        printf("\n--- MENU ENSEIGNANT ---\n");
        printf("1. Tester/Visualiser QCM 1\n");
        printf("2. Tester/Visualiser QCM 2\n");
        printf("3. Tester/Visualiser QCM 3\n");
        printf("4. Creer un nouveau QCM\n");
        printf("5. Retour au menu principal\n");
        printf("Choix : ");
        
        if (scanf("%d", &choix) != 1) {
            while(getchar() != '\n');
            continue;
        }

        switch (choix) {
            case 1: lancer_quizz(q1, "QCM 1"); break;
            case 2: lancer_quizz(q2, "QCM 2"); break;
            case 3: lancer_quizz(q3, "QCM 3"); break;
            case 4: creer_qcm(); break;
            case 5: break;
            default: printf("Choix invalide.\n");
        }
    } while (choix != 5);
}

