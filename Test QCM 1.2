




#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

typedef struct {
    char intitule[500];
    char propA[200];
    char propB[200];
    char propC[200];
    char propD[200];
    char bonne_reponse;
    int a_point_negatif;
} Question;

void poser_question(Question q, float *score, char *reponse_utilisateur) {
    char choix;
    int saisie_valide = 0;

    if (q.a_point_negatif) {
        printf("[ATTENTION : Points negatifs en cas d'erreur]\n");
    }

    printf("%s\n", q.intitule);
    printf("a) %s\n", q.propA);
    printf("b) %s\n", q.propB);
    printf("c) %s\n", q.propC);
    printf("d) %s\n", q.propD);

    while (!saisie_valide) {
        printf("Votre choix (a, b, c ou d) : ");
        scanf(" %c", &choix);
        choix = tolower(choix);

        if (choix >= 'a' && choix <= 'd') {
            saisie_valide = 1;
        } else {
            printf("Erreur : '%c' n'est pas une option valide. Veuillez recommencer.\n", choix);
        }
    }

    *reponse_utilisateur = choix;

    if (choix == q.bonne_reponse) {
        *score += 1.0;
    } else if (q.a_point_negatif) {
        *score -= 0.5;
    }
    
    printf("\n");
}

int main() {
    float score = 0.0;
    int i;
    char reponses_joueur[10];

    Question qcm1[10] = {
        {"Quel est l'indice de la premiere case d'un tableau de taille N ?", "1", "0", "N", "-1", 'b', 1},
        {"Comment appelle-t-on une variable declaree a l'interieur d'une fonction, qui n'est plus accessible une fois sorti de cette fonction ?", "Une variable globale", "Une variable statique", "Une variable locale", "Un parametre constant", 'c', 1},
        {"En langage C, quel format doit-on utiliser avec les fonctions printf et scanf pour manipuler une variable de type nombre entier (int) ?", "%f", "%c", "%d", "%e", 'c', 1},
        {"Quel operateur permet de recuperer l'adresse memoire d'une variable classique a ?", "*a", "&a", "%a", "@a", 'b', 1},
        {"Que contient exactement une variable de type pointeur ?", "Une valeur entiere aleatoire.", "L'adresse memoire d'une autre variable.", "Une copie de la variable qu'elle pointe.", "Le nom de la variable pointee.", 'b', 0},
        {"Dans un branchement conditionnel de type switch case en C, que se passe-t-il si le programmeur oublie d'ecrire l'instruction break; a la fin d'un case valide ?", "Le programme refuse de compiler.", "Le programme s'arrete et affiche un message d'erreur.", "Seul le case valide est execute, puis le programme sort.", "Il execute les instructions du case valide et continue sur les suivants.", 'd', 0},
        {"Quelle fonction de la bibliotheque <stdlib.h> est utilisee pour reserver manuellement un bloc de memoire lors de l'execution ?", "alloc()", "sizeof()", "malloc()", "free()", 'c', 0},
        {"Quel operateur doit-on utiliser pour acceder a un champ d'une structure si l'on manipule un pointeur pointant sur cette structure ?", ". (le point)", "-> (la fleche)", "* (l'etoile)", "& (l'esperluette)", 'b', 0},
        {"Quel element est absolument indispensable dans la conception d'une fonction recursive pour eviter un comportement infini ?", "Une condition d'arret qui ne fait pas d'appel recursif.", "Une boucle TANT QUE pour controler les iterations.", "Une variable globale pour compter les tours.", "Un tableau dynamique.", 'a', 0},
        {"Si un algorithme parcourt un tableau de taille n, quelle est sa complexite temporelle ?", "Constante, notee O(1)", "Lineaire, notee O(n)", "Logarithmique, notee O(log n)", "Quadratique, notee O(n^2)", 'b', 0}
    };

    printf("--- DEBUT DU QCM 1 ---\n\n");

    for (i = 0; i < 10; i++) {
        printf("Question %d/10 :\n", i + 1);
        poser_question(qcm1[i], &score, &reponses_joueur[i]);
    }

    /* Gestion de la note minimale a 0 */
    if (score < 0) {
        score = 0.0;
    }

    printf("--- RESULTATS ---\n");
    printf("Votre score final est : %.2f / 10.00\n\n", score);

    printf("--- CORRIGE DETAILLE ---\n");
    for (i = 0; i < 10; i++) {
        printf("Q%d : ", i + 1);
        if (reponses_joueur[i] == qcm1[i].bonne_reponse) {
            printf("Correct (%c)\n", qcm1[i].bonne_reponse);
        } else {
            printf("Faux. Vous avez mis '%c', la bonne reponse etait '%c'.\n", reponses_joueur[i], qcm1[i].bonne_reponse);
        }
    }

    return 0;
}






